# Khushdil Billing Buddy — environment variables example
# Copy to .env.local and fill with values from your Supabase project (Project Settings → API).
# Only VITE_* variables are exposed to the browser. NEVER commit real secrets.

VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_PUBLISHABLE_OR_ANON_KEY"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"
